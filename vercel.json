{
  "version": 2,
  "builds": [
    { "src": "api/navigator.js",  "use": "@vercel/node", "config": { "maxDuration": 30 } },
    { "src": "api/annotate.js",   "use": "@vercel/node", "config": { "maxDuration": 30 } },
    { "src": "api/survey.js",     "use": "@vercel/node", "config": { "maxDuration": 30 } },
    { "src": "**/*",             "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/navigator", "dest": "/api/navigator.js" },
    { "src": "/api/annotate",   "dest": "/api/annotate.js"  },
    { "src": "/api/survey",     "dest": "/api/survey.js"    },
    { "src": "/",              "dest": "/index.html"        },
    { "src": "/(.*)\\.(.+)",   "dest": "/$1.$2"            },
    { "src": "/(.*)",          "dest": "/$1.html"           }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
